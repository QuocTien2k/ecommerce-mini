model Brand {
  id        String   @id @default(uuid())

  name      String
  slug      String   @unique
  thumbnail String

  isActive  Boolean  @default(true)
  deletedAt DateTime?

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
  @@map("brands")
}
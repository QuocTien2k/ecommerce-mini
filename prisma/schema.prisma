
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING        // user vừa đặt (chưa xử lý)
  CONFIRMED      // admin xác nhận (hợp lệ, còn hàng)

  PROCESSING     // đang lấy hàng / đóng gói
  READY_TO_SHIP  // đã ra kho

  SHIPPING       // đang vận chuyển
  DELIVERED      // giao thành công

  CANCELLED      // hủy (bất kỳ stage trước delivered)
}
enum Role {
  USER
  ADMIN
}
enum VoucherScope {
  ORDER
  PRODUCT
  CATEGORY
}
enum VoucherType {
  PERCENT   // giảm theo %
  FIXED     // giảm số tiền cố định
}
model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  isRevoked   Boolean  @default(false)
  expiresAt   DateTime

  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("refresh_token")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  isUsed    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}
model CartItem {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  quantity    Int      @default(1)

  // snapshot
  price       Decimal  @db.Decimal(10, 2)
  productName String
  productImage String?

  // optional nhưng nên có
  selectedAttributes Json? // size, color snapshot

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, variantId]) // 1 variant chỉ xuất hiện 1 lần trong cart
  @@index([userId])
  @@index([variantId])
  @@map("cart_items")
}
model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  imagePublicId String?

  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")

  isActive    Boolean   @default(true)
  deletedAt   DateTime?

  products    Product[]
  vouchers Voucher[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([parentId])
  @@map("categories")
}
model Notification {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  title     String
  message   String

  isRead    Boolean  @default(false)

  // optional reference (liên kết order)
  orderId String?
  order   Order? @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}
model OrderItem {
  id          String   @id @default(uuid())

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])

  productId   String
  variantId   String

  quantity    Int

  // snapshot
  price       Decimal  @db.Decimal(10, 2)
  productName String
  productImage String?
  selectedAttributes Json?

  createdAt   DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}
model Order {
  id            String   @id @default(uuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  status        OrderStatus @default(PENDING)

  //Pricing
  subtotal        Decimal @db.Decimal(12, 2) // tổng trước giảm
  discountAmount  Decimal @default(0) @db.Decimal(12, 2)
  totalPrice      Decimal @db.Decimal(12, 2)

  //Voucher snapshot
  voucherCode     String?
  voucherType     VoucherType? // PERCENT | FIXED
  voucherValue    Decimal? @db.Decimal(10, 2)

  //Receiver snapshot
  receiverName    String
  receiverPhone   String
  receiverAddress String

  //Metadata
  note            String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           OrderItem[]
  notifications Notification[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}
model ProductVariant {
  id              String   @id @default(uuid())

  productId       String
  product         Product  @relation(fields: [productId], references: [id])

  color           String
  attributes      Json?
  attributesHash  String?

  images          String[]
  imagePublicIds  String[]

  stock           Int      @default(0)

  cartItems       CartItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, color, attributesHash])
  @@index([productId])
  @@map("product_variants")
}
model Product {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?

  price         Decimal @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)
  discountPct   Int?

  ratingAvg     Float  @default(0)
  ratingCount   Int    @default(0)

  isActive      Boolean @default(true)

  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])

  creatorId     String
  creator       User   @relation("UserProducts", fields: [creatorId], references: [id])

  variants      ProductVariant[]
  ratings       Rating[]
  cartItems     CartItem[]
  vouchers Voucher[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoryId])
  @@map("products")
}
model Rating {
  id        String   @id @default(uuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  value     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@map("ratings")
}
model UserVoucher {
  id        String @id @default(uuid())

  userId    String
  voucherId String

  usedCount Int @default(0)
  used      Boolean @default(false)

  assignedAt DateTime @default(now())
  usedAt     DateTime?
  usagePerUser Int?
  
  remainingUsage Int? // = usagePerUser - usedCount

  user     User    @relation(fields: [userId], references: [id])
  voucher  Voucher @relation(fields: [voucherId], references: [id])

  @@unique([userId, voucherId])
}
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?  @unique
  fullname  String
  password  String
  avatar    String?
  avatarPublicId String?
  address   String?
  role      Role     @default(USER)

  products  Product[]   @relation("UserProducts")
  ratings   Rating[]
  cartItems CartItem[]
  orders    Order[]
  notifications Notification[]
  userVouchers UserVoucher[]

  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
model Voucher {
  id          String   @id @default(uuid())

  code        String   @unique
  type        VoucherType

  value       Decimal  @db.Decimal(10, 2) // % hoặc số tiền
  maxDiscount Decimal? @db.Decimal(10, 2) // giới hạn giảm (cho PERCENT)

  minOrderValue Decimal? @db.Decimal(12, 2)

  usageLimit   Int?     // tổng số lượt dùng
  usedCount    Int      @default(0)

  scope VoucherScope @default(ORDER)

  isActive     Boolean  @default(true)

  startAt      DateTime?
  endAt        DateTime?

  userVouchers UserVoucher[]
  products   Product[]   //  scope = PRODUCT
  categories Category[]  //  scope = CATEGORY

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([code])
  @@map("vouchers")
}
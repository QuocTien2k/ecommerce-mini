model Voucher {
  id          String   @id @default(uuid())

  code        String   @unique
  type        VoucherType

  value       Decimal  @db.Decimal(10, 2) // % hoặc số tiền
  maxDiscount Decimal? @db.Decimal(10, 2) // giới hạn giảm (cho PERCENT)

  minOrderValue Decimal? @db.Decimal(12, 2)

  usageLimit   Int?     // tổng số lượt dùng
  usedCount    Int      @default(0)

  isActive     Boolean  @default(true)

  startAt      DateTime?
  endAt        DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([code])
  @@map("vouchers")
}
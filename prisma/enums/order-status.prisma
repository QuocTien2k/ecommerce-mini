enum OrderStatus {
  PENDING        // user vừa đặt (chưa xử lý)
  CONFIRMED      // admin xác nhận (hợp lệ, còn hàng)

  PROCESSING     // đang lấy hàng / đóng gói
  READY_TO_SHIP  // đã ra kho

  SHIPPING       // đang vận chuyển
  DELIVERED      // giao thành công

  CANCELLED      // hủy (bất kỳ stage trước delivered)
}